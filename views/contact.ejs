<%- include('partials/header') %>

<h1 class="page-title">聯絡資訊</h1>

<div class="card" style="max-width: 560px;">
  <% if (success) { %>
    <div class="success-msg">訊息已送出，我們會盡快與您聯繫！</div>
  <% } %>
  <% if (errors.length > 0) { %>
    <div class="errors">
      <ul style="margin: 0; padding-left: 18px;">
        <% errors.forEach(e => { %><li><%= e %></li><% }) %>
      </ul>
    </div>
  <% } %>

  <form method="POST" action="/contact">
    <div class="field">
      <label>姓名</label>
      <input type="text" name="name" value="<%= form.name || '' %>" required />
    </div>
    <div class="field">
      <label>Email</label>
      <input type="email" name="email" value="<%= form.email || '' %>" required />
    </div>
    <div class="field">
      <label>主旨</label>
      <input type="text" name="subject" value="<%= form.subject || '' %>" />
    </div>
    <div class="field">
      <label>訊息內容</label>
      <textarea name="message" rows="5" required><%= form.message || '' %></textarea>
    </div>
    <button type="submit" class="btn">送出訊息</button>
  </form>
</div>

<div class="card" style="max-width: 560px;">
  <h3>其他聯絡方式</h3>
  <p style="color: var(--muted);">Email: example@example.com</p>
  <p style="color: var(--muted);">這裡之後可以放上你真實的聯絡資訊。</p>
</div>

<%- include('partials/footer') %>
