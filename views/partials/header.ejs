<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | 期末專題</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <div class="bg-hero">
    <div class="bg-overlay"></div>
    <div class="bg-glow glow-1"></div>
    <div class="bg-glow glow-2"></div>
    <div class="bg-glow glow-3"></div>
  </div>

  <header class="site-header">
    <div class="container header-inner">
      <a class="brand" href="/">期末專題</a>
      <button class="nav-toggle" id="navToggle" aria-label="開啟選單">☰</button>
      <nav class="main-nav" id="mainNav">
        <a href="/">首頁</a>
        <a href="/about">關於我們</a>
        <a href="/portfolio">作品集</a>
        <a href="/articles">文章列表</a>
        <a href="/contact">聯絡資訊</a>
        <% if (currentUser) { %>
          <% if (currentUser.role === 'admin') { %>
            <a href="/admin">後台管理</a>
          <% } %>
          <span class="nav-user">你好，<%= currentUser.username %></span>
          <form action="/logout" method="POST" class="inline-form">
            <button type="submit" class="link-btn">登出</button>
          </form>
        <% } else { %>
          <a href="/login">登入</a>
          <a href="/register">註冊</a>
        <% } %>
      </nav>
    </div>
  </header>

  <main class="container page-content">
