<%- include('partials/header') %>

<div class="auth-page">
<h1 class="page-title">登入</h1>

<div class="card auth-card" style="max-width: 420px;">
  <% if (errors.length > 0) { %>
    <div class="errors">
      <ul style="margin: 0; padding-left: 18px;">
        <% errors.forEach(e => { %><li><%= e %></li><% }) %>
      </ul>
    </div>
  <% } %>
  <form method="POST" action="/login">
    <input type="hidden" name="redirectTo" value="<%= redirectTo %>" />
    <div class="field">
      <label>帳號 / Email</label>
      <input type="text" name="username" value="<%= form.username || '' %>" required />
    </div>
    <div class="field">
      <label>密碼</label>
      <input type="password" name="password" required />
    </div>
    <button type="submit" class="btn">登入</button>
  </form>
  <p style="color: var(--muted); margin-top: 16px;">還沒有帳號？<a href="/register" style="color: var(--neon-cyan);">立即註冊</a></p>
  <p style="color: var(--muted); font-size: 0.8rem;">測試帳號：admin / admin1234（管理員）、小火 / user1234（一般使用者）</p>
</div>
</div>

<%- include('partials/footer') %>
