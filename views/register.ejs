<%- include('partials/header') %>

<div class="auth-page">
<h1 class="page-title">註冊</h1>

<div class="card auth-card" style="max-width: 420px;">
  <% if (errors.length > 0) { %>
    <div class="errors">
      <ul style="margin: 0; padding-left: 18px;">
        <% errors.forEach(e => { %><li><%= e %></li><% }) %>
      </ul>
    </div>
  <% } %>
  <form method="POST" action="/register">
    <div class="field">
      <label>使用者名稱</label>
      <input type="text" name="username" value="<%= form.username || '' %>" required />
    </div>
    <div class="field">
      <label>Email</label>
      <input type="email" name="email" value="<%= form.email || '' %>" required />
    </div>
    <div class="field">
      <label>密碼</label>
      <input type="password" name="password" required />
    </div>
    <div class="field">
      <label>確認密碼</label>
      <input type="password" name="confirm" required />
    </div>
    <button type="submit" class="btn">註冊</button>
  </form>
  <p style="color: var(--muted); margin-top: 16px;">已經有帳號了？<a href="/login" style="color: var(--neon-cyan);">前往登入</a></p>
</div>
</div>

<%- include('partials/footer') %>
