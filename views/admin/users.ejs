<%- include('../partials/header') %>

<h1 class="page-title">使用者管理</h1>
<%- include('../partials/admin-tabs', { active: 'users' }) %>

<div class="table-wrap card">
  <table>
    <thead><tr><th>使用者名稱</th><th>Email</th><th>角色</th><th>狀態</th><th>註冊時間</th><th>操作</th></tr></thead>
    <tbody>
      <% users.forEach(u => { %>
        <tr>
          <td><%= u.username %></td>
          <td><%= u.email %></td>
          <td><span class="badge badge-<%= u.role %>"><%= u.role %></span></td>
          <td><span class="badge badge-<%= u.status %>"><%= u.status %></span></td>
          <td><%= u.created_at %></td>
          <td style="display: flex; gap: 6px; flex-wrap: wrap;">
            <form action="/admin/users/<%= u.id %>/role" method="POST">
              <input type="hidden" name="role" value="<%= u.role === 'admin' ? 'user' : 'admin' %>" />
              <button type="submit" class="btn btn-sm btn-secondary"><%= u.role === 'admin' ? '降為一般使用者' : '設為管理員' %></button>
            </form>
            <form action="/admin/users/<%= u.id %>/status" method="POST">
              <input type="hidden" name="status" value="<%= u.status === 'banned' ? 'active' : 'banned' %>" />
              <button type="submit" class="btn btn-sm <%= u.status === 'banned' ? '' : 'btn-danger' %>"><%= u.status === 'banned' ? '解除停權' : '停權' %></button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('../partials/footer') %>
